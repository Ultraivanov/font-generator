{
  "name": "parametric-font",
  "version": "0.1.0",
  "description": "Programmatic font generation inspired by Swiss typography",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "generate": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test:visual": "node tests/visual-regression.js",
    "test:stem": "node tests/stem-analyzer.js",
    "test:kerning": "node tests/kerning-validator.js",
    "test:all": "npm run test:visual && npm run test:stem && npm run test:kerning",
    "test:R": "tsx tests/test-R.ts"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0"
  }
}
